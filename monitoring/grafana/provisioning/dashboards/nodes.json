{
  "title": "Node Metrics",
  "uid": "brickprofit-nodes",
  "timezone": "browser",
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["nodes", "infrastructure"],
  "panels": [
    {
      "id": 1, "type": "row", "title": "CPU", "gridPos": {"h":1,"w":24,"x":0,"y":0}, "collapsed": false
    },
    {
      "id": 2,
      "title": "CPU Usage %",
      "type": "timeseries",
      "gridPos": {"h":8,"w":24,"x":0,"y":1},
      "datasource": {"type":"prometheus","uid":"${datasource}"},
      "options": {"legend": {"displayMode": "table", "placement": "bottom"}},
      "fieldConfig": {
        "defaults": {"unit": "percent", "min": 0, "max": 100, "custom": {"lineWidth": 2}},
        "overrides": []
      },
      "targets": [
        {
          "expr": "100 - (avg by(instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[2m])) * 100)",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3, "type": "row", "title": "Memory", "gridPos": {"h":1,"w":24,"x":0,"y":9}, "collapsed": false
    },
    {
      "id": 4,
      "title": "Memory Usage %",
      "type": "timeseries",
      "gridPos": {"h":8,"w":12,"x":0,"y":10},
      "datasource": {"type":"prometheus","uid":"${datasource}"},
      "options": {"legend": {"displayMode": "table", "placement": "bottom"}},
      "fieldConfig": {
        "defaults": {"unit": "percent", "min": 0, "max": 100, "custom": {"lineWidth": 2}},
        "overrides": []
      },
      "targets": [
        {
          "expr": "100 * (1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes))",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Memory Available",
      "type": "timeseries",
      "gridPos": {"h":8,"w":12,"x":12,"y":10},
      "datasource": {"type":"prometheus","uid":"${datasource}"},
      "options": {"legend": {"displayMode": "table", "placement": "bottom"}},
      "fieldConfig": {
        "defaults": {"unit": "bytes", "custom": {"lineWidth": 2}},
        "overrides": []
      },
      "targets": [
        {
          "expr": "node_memory_MemAvailable_bytes",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6, "type": "row", "title": "Disk", "gridPos": {"h":1,"w":24,"x":0,"y":18}, "collapsed": false
    },
    {
      "id": 7,
      "title": "Disk Usage % (root)",
      "type": "timeseries",
      "gridPos": {"h":8,"w":12,"x":0,"y":19},
      "datasource": {"type":"prometheus","uid":"${datasource}"},
      "options": {"legend": {"displayMode": "table", "placement": "bottom"}},
      "fieldConfig": {
        "defaults": {"unit": "percent", "min": 0, "max": 100, "custom": {"lineWidth": 2}},
        "overrides": []
      },
      "targets": [
        {
          "expr": "100 - (node_filesystem_avail_bytes{mountpoint=\"/\",fstype!=\"tmpfs\"} / node_filesystem_size_bytes{mountpoint=\"/\",fstype!=\"tmpfs\"} * 100)",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "title": "Disk I/O",
      "type": "timeseries",
      "gridPos": {"h":8,"w":12,"x":12,"y":19},
      "datasource": {"type":"prometheus","uid":"${datasource}"},
      "options": {"legend": {"displayMode": "table", "placement": "bottom"}},
      "fieldConfig": {
        "defaults": {"unit": "Bps", "custom": {"lineWidth": 2}},
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(node_disk_read_bytes_total[2m])",
          "legendFormat": "{{instance}} read",
          "refId": "A"
        },
        {
          "expr": "rate(node_disk_written_bytes_total[2m])",
          "legendFormat": "{{instance}} write",
          "refId": "B"
        }
      ]
    },
    {
      "id": 9, "type": "row", "title": "Network", "gridPos": {"h":1,"w":24,"x":0,"y":27}, "collapsed": false
    },
    {
      "id": 10,
      "title": "Network Traffic",
      "type": "timeseries",
      "gridPos": {"h":8,"w":24,"x":0,"y":28},
      "datasource": {"type":"prometheus","uid":"${datasource}"},
      "options": {"legend": {"displayMode": "table", "placement": "bottom"}},
      "fieldConfig": {
        "defaults": {"unit": "bps", "custom": {"lineWidth": 2}},
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(node_network_receive_bytes_total{device!~\"lo|veth.*|docker.*|br.*|overlay.*\"}[2m]) * 8",
          "legendFormat": "{{instance}} {{device}} rx",
          "refId": "A"
        },
        {
          "expr": "rate(node_network_transmit_bytes_total{device!~\"lo|veth.*|docker.*|br.*|overlay.*\"}[2m]) * 8",
          "legendFormat": "{{instance}} {{device}} tx",
          "refId": "B"
        }
      ]
    },
    {
      "id": 11, "type": "row", "title": "System", "gridPos": {"h":1,"w":24,"x":0,"y":36}, "collapsed": false
    },
    {
      "id": 12,
      "title": "System Load (1m)",
      "type": "timeseries",
      "gridPos": {"h":8,"w":12,"x":0,"y":37},
      "datasource": {"type":"prometheus","uid":"${datasource}"},
      "options": {"legend": {"displayMode": "table", "placement": "bottom"}},
      "fieldConfig": {
        "defaults": {"custom": {"lineWidth": 2}},
        "overrides": []
      },
      "targets": [
        {
          "expr": "node_load1",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 13,
      "title": "Uptime",
      "type": "stat",
      "gridPos": {"h":8,"w":12,"x":12,"y":37},
      "datasource": {"type":"prometheus","uid":"${datasource}"},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "auto", "textMode": "auto", "colorMode": "value"},
      "fieldConfig": {
        "defaults": {"unit": "s"},
        "overrides": []
      },
      "targets": [
        {
          "expr": "node_time_seconds - node_boot_time_seconds",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    }
  ],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "pluginId": "prometheus",
        "label": "Datasource",
        "hide": 0
      }
    ]
  },
  "time": {"from": "now-1h", "to": "now"}
}
