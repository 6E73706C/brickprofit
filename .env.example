# ─── Registry ───────────────────────────────────────────────────────────────
REGISTRY=registry.yourdomain.com
TAG=latest

# ─── Domain ──────────────────────────────────────────────────────────────────
DOMAIN=brickprofit.net

# ─── App ─────────────────────────────────────────────────────────────────────
SECRET_KEY=changeme-use-a-long-random-string

# ─── Cassandra ───────────────────────────────────────────────────────────────
CASSANDRA_CLUSTER_NAME=BrickProfitCluster
CASSANDRA_KEYSPACE=brickprofit
CASSANDRA_USER=brickprofit
CASSANDRA_PASSWORD=changeme-cassandra

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_PASSWORD=changeme-redis

# ─── Monitoring ──────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=changeme-grafana
